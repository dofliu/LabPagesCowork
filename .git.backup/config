[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
	quotePath = false
[remote "origin"]
	url = https://github.com/dofliu/LabPagesCowork.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main"]
	remote = origin
	merge = refs/heads/main
[branch "feature/refresh-2026"]
	remote = origin
	merge = refs/heads/feature/refresh-2026
	vscode-merge-base = origin/main
[remote "oldsite"]
	url = https://github.com/dofliu/doflabPages.git
	fetch = +refs/heads/*:refs/remotes/oldsite/*
[branch "feature/add-dashboard"]
	remote = origin
	merge = refs/heads/feature/add-dashboard
